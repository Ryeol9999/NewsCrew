# =========================
# 1. API Keys & Secrets (가장 중요)
# =========================
# OpenAI API 키 등 민감한 환경 변수가 포함된 파일은 절대 커밋되지 않도록 합니다.
.env
.env.*
*.pem
*.key

# =========================
# 2. Python & Virtual Environments
# =========================
# Python 캐시 파일
__pycache__/
*.py[cod]
*$py.class

# uv, venv 등 가상 환경 디렉토리
.venv/
venv/
env/
ENV/

# Python 패키징 및 빌드 결과물
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# =========================
# 3. LangGraph, Data & Logs
# =========================
# LangGraph 체크포인트(메모리)용 로컬 DB 또는 상태 파일
*.sqlite
*.sqlite3
*.db

# 에이전트 실행 및 시스템 로그
*.log
logs/

# 로컬 테스트용 데이터셋 및 결과물 (필요에 따라 주석 해제)
# data/
# output/

# =========================
# 4. OS & IDE
# =========================
# macOS 시스템 파일
.DS_Store
.AppleDouble
.LSOverride

# Windows 시스템 파일
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE 설정 파일 (VSCode, PyCharm 등)
.vscode/
.idea/
*.swp